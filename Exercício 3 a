package Lista1;

import java.util.Scanner;

public class Exercicio_3a {

	public static void main(String[] args) {
	
		Scanner s = new Scanner(System.in);
		
		int num;
		int totalpositivos = 0;
		int somapositivos = 0;
		
		for (int i = 1; i <= 10; i++) {
		
		System.out.println("Digite seu " + i + "° valor");
		num = s.nextInt();
		
		if (num > 0) {
			somapositivos += num;
			totalpositivos++;
		}
		
		}
		
		if (totalpositivos > 0) {
			double media = somapositivos / totalpositivos;
			System.out.println("A média de números positivos é: " + media);
		}
		
			else {
				System.out.println("Não tem número positivo");
				
			}
		}

		}
	
