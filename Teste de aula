package Lista1;

import java.text.DecimalFormat;
import java.util.Scanner;
	
public class Teste_1 {

	public static void main(String[] args) {
		
		Scanner s = new Scanner(System.in);
	    DecimalFormat df = new DecimalFormat("##0.0");
		
		System.out.println("Quantas repetições quer?");
		int limite=s.nextInt();

		int soma = 0;
			int maiorValor = Integer.MIN_VALUE;
			
		for (int i = 1; i <= limite; i++) {
			System.out.println("Informe o valor " + i);
		    int valor = s.nextInt();
		    
		    soma += valor;
		    if (valor > maiorValor)
		    	maiorValor = valor;
		}
		
		System.out.println("A média é:" + df.format(soma/limite));
		System.out.println("O maior valor informado foi: " + maiorValor);
		
		
	}

}
